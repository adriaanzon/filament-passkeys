{
    "name": "adriaanzon/filament-passkeys",
    "description": "Filament Passkey MFA using laravel/passkeys",
    "keywords": [
        "adriaanzon",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-passkeys",
        "webauthn",
        "fortify"
    ],
    "homepage": "https://github.com/adriaanzon/filament-passkeys",
    "support": {
        "issues": "https://github.com/adriaanzon/filament-passkeys/issues",
        "source": "https://github.com/adriaanzon/filament-passkeys"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Adriaan Zonnenberg",
            "email": "git@adriaan.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.3.5",
        "laravel/passkeys": "^0.2",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AdriaanZon\\FilamentPasskeys\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdriaanZon\\FilamentPasskeys\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "AdriaanZon\\FilamentPasskeys\\FilamentPasskeysServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
